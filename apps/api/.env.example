PORT=3000
CORS_ORIGIN=http://localhost:3001

# Preferred Mongo connection string for the Nest API.
MONGO_URI=mongodb://user:password@localhost:27017/conteai

# Legacy Mongo variables are also accepted during the port.
MONGOUSER=user
MONGOPASS=password
MONGOIP=localhost
MONGOPORT=27017
MONGODBNAME=conteai

JWT_SECRET=change-me

BUCKET_KEY=change-me
BUCKET_SECRET=change-me
BUCKET_REGION=us-east-1
BUCKET_NAME=conteai-images
BUCKET_API=https://s3.example.com
BUCKET_URL=https://cdn.example.com

# Preferred name; legacy GOOGLEAPIKEY is also accepted.
GOOGLE_API_KEY=change-me
GOOGLEAPIKEY=change-me
