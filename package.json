{
  "name": "conteai",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=26 <27"
  },
  "scripts": {
    "lint": "pnpm lint:biome && pnpm --filter web --if-present lint",
    "lint:biome": "biome check .",
    "format": "biome format --write .",
    "typecheck": "pnpm -r --if-present typecheck",
    "test": "pnpm -r --if-present test",
    "build": "pnpm -r --if-present build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@sentiness/check-biome": "0.1.0",
    "@sentiness/check-deps-diff": "0.1.0",
    "@sentiness/check-eslint": "0.1.0",
    "@sentiness/check-knip": "0.1.0",
    "@sentiness/core": "0.1.3",
    "eslint": "10.4.1",
    "knip": "6.16.1",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "overrides": {
      "@nuxt/cli": "3.31.1",
      "@nuxt/devtools": "3.1.1"
    }
  }
}
